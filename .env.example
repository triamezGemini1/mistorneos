# Mistorneos — copiar a .env (no subir .env al repositorio)

APP_ENV=development

# Base de datos principal: tabla maestra usuarios, torneos, login, buscador del landing
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mistorneos
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Tabla maestra de cuentas (solo usuarios | users)
# DB_AUTH_TABLE=usuarios

# Base de datos AUXILIAR de personas (~32M): padrón para consultarPadron() y registro rápido (no login).
DB_SECONDARY_HOST=localhost
DB_SECONDARY_PORT=3306
DB_SECONDARY_DATABASE=
DB_SECONDARY_USERNAME=
DB_SECONDARY_PASSWORD=

# Tabla del padrón (IDUsuario, Nac, Nombre1…, FNac, Sexo). Ver PersonaAuxConfig.
# DB_PERSONA_TABLE=dbo_persona
